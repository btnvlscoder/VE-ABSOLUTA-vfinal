# ==========================================
# ARCHIVO DE EJEMPLO - Variables de Entorno
# ==========================================
# Copia este archivo como .env y llena los valores reales

# ---------------------------
# BASE DE DATOS (NEON)
# ---------------------------
NEON_DB_URL=jdbc:postgresql://your-neon-host:5432/your-database
NEON_DB_USER=your-username
NEON_DB_PASSWORD=your-password

# ---------------------------
# CLOUDINARY
# ---------------------------
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ---------------------------
# AI SERVICE (PYTHON FASTAPI)
# ---------------------------
AI_SERVICE_URL=http://localhost:8000

# ---------------------------
# HUGGING FACE (AI ENGINE)
# ---------------------------
HUGGING_FACE_TOKEN=hf_your-token-here
HF_MODEL_DIR=btnvlscoder/ve-absoluta-vit-v2
